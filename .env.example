# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
# On Vercel, set these same keys under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Neon or Supabase free tier).
# Neon:     https://neon.tech      → dashboard → Connection string (pooled)
# Supabase: https://supabase.com   → Project → Settings → Database → URI
# Example:  postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: token/market data source API key (add when you wire a real feed).
# DATA_API_KEY=
