# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
# On Vercel, set these same keys under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Neon or Supabase free tier).
# Neon:     https://neon.tech      → dashboard → Connection string (pooled)
# Supabase: https://supabase.com   → Project → Settings → Database → URI
# Example:  postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: token/market data source API key (add when you wire a real feed).
# DATA_API_KEY=

# ─── CandleTG tool (/api/candle-tg/*) ────────────────────────────────────────
# Leave all blank to disable the tool — the builder shows an "unconfigured"
# state and the build/check-link endpoints return 503 instead of crashing.
#
# Telegram builder account (GramJS StringSession + app credentials from
# my.telegram.org). Required to create groups/channels.
TG_SESSION=
TG_API_ID=
TG_API_HASH=
# Solana token metadata (name/ticker/logo). Recommended; without it CandleTG
# falls back to the Jupiter token list.
HELIUS_API_KEY=
# Optional: bot token + chat id for owner "build complete" notifications.
BOT_TOKEN=
OWNER_CHAT_ID=
